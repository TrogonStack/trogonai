#!/usr/bin/env python3
#MISE description="Assert every ADR#NNNN reference in markdown is a link that resolves to its docs/adr/NNNN-*.md file"

"""Lint ADR references.

Rules (applied to every `ADR#NNNN` where NNNN is exactly 4 digits):
  A. The reference must be a markdown link: `[ADR#NNNN: ...](target)`.
     Exception: the `# ADR#NNNN: ...` title heading inside docs/adr/NNNN-*.md.
  B. The link target must resolve (relative to the file) to an existing
     docs/adr/NNNN-*.md whose leading number equals NNNN.

Non-4-digit forms (e.g. ADR#6310044131 research placeholders) are ignored.

Exit code 1 if any violation is found.
"""

from __future__ import annotations

import os
import re
import subprocess
import sys
from pathlib import Path


def repo_root() -> Path:
    env = os.environ.get("GITHUB_WORKSPACE")
    if env:
        return Path(env)
    out = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
        check=True,
    ).stdout.strip()
    return Path(out)


REPO = repo_root()
ADR_DIR = REPO / "docs" / "adr"

# exactly-4-digit form only (so research pseudo-IDs like ADR#6310044131 are ignored)
N = r"(?<!\d)(\d{4})(?!\d)"
# `[ADR#0002: optional title](../../docs/adr/0002-foo.md)` -> capture number + target
LINK_RE = re.compile(r"\[ADR#" + N + r"[^\]]*\]\(([^)]+)\)")
# any 4-digit reference, used to find the ones NOT wrapped in a link
ANY_RE = re.compile(r"ADR#" + N)
# title heading exemption: `# ADR#0002: ...`
HEADING_RE = re.compile(r"^#{1,6}\s+ADR#" + N + r"\b")


def adr_number_for(path: Path) -> str | None:
    """Return the 4-digit number if path is an ADR file, else None."""
    m = re.match(r"(\d{4})-", path.name)
    return m.group(1) if path.parent == ADR_DIR and m else None


def iter_markdown() -> list[Path]:
    return [
        p
        for p in REPO.rglob("*.md")
        if "node_modules" not in p.parts and ".git" not in p.parts
    ]


def check_file(path: Path) -> list[str]:
    problems: list[str] = []
    self_num = adr_number_for(path)
    text = path.read_text(encoding="utf-8", errors="replace")

    # Char-offset ranges already inside a valid link label, so we don't
    # double-flag them as bare references.
    linked_spans: list[tuple[int, int]] = []

    for m in LINK_RE.finditer(text):
        num, target = m.group(1), m.group(2).split("#")[0].strip()
        linked_spans.append(m.span())
        resolved = (path.parent / target).resolve()
        tgt_num = adr_number_for(resolved) if resolved.parent == ADR_DIR else None
        line = text.count("\n", 0, m.start()) + 1
        rel = path.relative_to(REPO)
        if not resolved.exists():
            problems.append(f"{rel}:{line}: ADR#{num} link target does not exist: {target}")
        elif tgt_num != num:
            problems.append(f"{rel}:{line}: ADR#{num} links to mismatched file: {target}")

    for m in ANY_RE.finditer(text):
        start = m.start()
        if any(a <= start < b for a, b in linked_spans):
            continue  # part of a valid link label
        num = m.group(1)
        line_start = text.rfind("\n", 0, start) + 1
        line_end = text.find("\n", start)
        line_text = text[line_start : line_end if line_end != -1 else len(text)]
        line = text.count("\n", 0, start) + 1

        hm = HEADING_RE.match(line_text)
        if hm and hm.group(1) == num and self_num == num:
            continue  # the ADR's own title heading

        problems.append(
            f"{path.relative_to(REPO)}:{line}: bare ADR#{num} is not a markdown link "
            f"(use [ADR#{num}](<relative-path-to-{num}-*.md>))"
        )
    return problems


def main() -> int:
    if not ADR_DIR.is_dir():
        print(f"error: {ADR_DIR} not found", file=sys.stderr)
        return 2
    problems: list[str] = []
    for path in iter_markdown():
        problems.extend(check_file(path))

    if problems:
        for p in sorted(problems):
            print(p)
        print(f"\n{len(problems)} ADR reference problem(s) found.", file=sys.stderr)
        return 1
    print("All ADR references are properly linked.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
