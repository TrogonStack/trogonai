{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://trogon.ai/a2a/schemas/agent-card.min.json",
  "title": "AgentCard",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "supportedInterfaces"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "supportedInterfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["url", "protocolBinding", "protocolVersion"],
        "properties": {
          "url": {
            "type": "string",
            "pattern": "^https?://[^\\s]+$"
          },
          "protocolBinding": {
            "type": "string",
            "minLength": 1
          },
          "protocolVersion": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
