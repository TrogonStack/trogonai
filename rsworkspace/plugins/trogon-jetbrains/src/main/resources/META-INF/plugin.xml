<idea-plugin>
    <id>ai.trogon.jetbrains</id>
    <name>Trogon AI</name>
    <vendor email="hello@trogon.ai" url="https://trogon.ai">Trogon AI</vendor>
    <description><![CDATA[
        Trogon AI coding assistant for JetBrains IDEs.<br/>
        <ul>
            <li>Chat panel with real-time streaming responses</li>
            <li>Inline diff display with accept/reject changes</li>
            <li>Slash commands: /clear, /help</li>
            <li>Ask Trogon about selected code (Ctrl+Shift+T)</li>
        </ul>
        Requires <code>trogon</code> CLI on PATH (or configure the path in Settings → Trogon AI).
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <toolWindow id="Trogon"
                    secondary="false"
                    anchor="right"
                    factoryClass="ai.trogon.jetbrains.TrogonToolWindowFactory"
                    icon="/icons/trogon.svg"/>

        <!-- Application-level settings: trogon binary path -->
        <applicationService
            serviceImplementation="ai.trogon.jetbrains.TrogonSettings"/>

        <!-- Project-level service: manages the trogon subprocess -->
        <projectService
            serviceImplementation="ai.trogon.jetbrains.TrogonService"/>

        <!-- Settings page under Tools → Trogon AI -->
        <applicationConfigurable
            parentId="tools"
            instance="ai.trogon.jetbrains.TrogonSettingsConfigurable"
            id="ai.trogon.settings"
            displayName="Trogon AI"/>

    </extensions>

    <actions>
        <action id="ai.trogon.AskTrogon"
                class="ai.trogon.jetbrains.TrogonAction"
                text="Ask Trogon"
                description="Send selected code to the Trogon AI chat panel">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift T"/>
        </action>
    </actions>
</idea-plugin>
