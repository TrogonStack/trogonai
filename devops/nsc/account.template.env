# Per-tenant A2A Account bootstrap variables.
#
# Consumed by scripts/a2a-nsc-bootstrap.sh and devops/nsc/bootstrap.sh.
# One Account == one tenant boundary (subject namespace + JetStream quota).

# Account name.
export A2A_ACCOUNT_NAME="tenant-acme"

# Subject prefix on the data plane (default `a2a`).
export A2A_PREFIX="a2a"

# JetStream KV bucket for AgentCards (default A2A_AGENT_CARDS).
export A2A_CATALOG_KV_BUCKET="A2A_AGENT_CARDS"

# JetStream tenant quotas — tune per tier.
export A2A_JS_MEM_STORAGE="1G"
export A2A_JS_DISK_STORAGE="10G"
export A2A_JS_STREAMS="10"
export A2A_JS_CONSUMERS="50"

# Set to "0" to skip `nsc push` (offline / preview runs).
export A2A_PUSH_JWT="1"
