# NSC operator bootstrap variables (one per NATS cluster).
#
# Source this file then run the nsc commands in devops/nsc/README.md.
# No key material lives in this file — only naming / topology.

# Operator name registered with NSC.
export NSC_OPERATOR_NAME="trogon-prod"

# NSC home directory (passed to --config-dir / --data-dir / --keystore-dir).
export NSC_HOME="${HOME}/.local/share/nats/nsc"

# Resolver URL the operator publishes Account JWTs to. Match your NATS
# server config block (`operator: <op_jwt>` + `resolver: { type: full, dir: … }`).
export NSC_RESOLVER_URL="nats://nats.trogon.svc.cluster.local:4222"

# Operator signing-key directory (NKEY seeds). Mount as a Kubernetes
# Secret in production; never check key material into Git.
export NSC_OPERATOR_KEY_DIR="${NSC_HOME}/keys/keys/O"
