# --- Gateway ---
# TROGON_GATEWAY_PORT=8080
#
# Docker Compose mounts services/trogon-gateway/gateway.toml by default. That
# local config enables /sources/github/local/webhook with this dev-only secret.
TROGON_GATEWAY_LOCAL_GITHUB_WEBHOOK_SECRET=local-dev-secret
#
# Secret fields can reference environment variables from TOML, for example:
# webhook_secret = { env = "GITHUB_ACME_MAIN_WEBHOOK_SECRET" }
# bot_token = { env = "DISCORD_BOT_TOKEN" }
# GITHUB_ACME_MAIN_WEBHOOK_SECRET=
# GITHUB_ACME_EU_WEBHOOK_SECRET=
# SLACK_PRIMARY_SIGNING_SECRET=
# TELEGRAM_PRIMARY_WEBHOOK_SECRET=
# TELEGRAM_PRIMARY_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# --- NATS ---
# NATS_URL=nats://localhost:4222

# --- Logging ---
# RUST_LOG=info

# --- Dev (ngrok tunnels) ---
# NGROK_AUTHTOKEN=
