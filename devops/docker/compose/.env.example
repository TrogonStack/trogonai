# --- Gateway ---
# TROGON_GATEWAY_PORT=8080
#
# Docker Compose mounts ./services/trogon-gateway/gateway.toml by default. That
# local config enables /sources/github/local/webhook with this dev-only secret.
TROGON_GATEWAY_LOCAL_GITHUB_WEBHOOK_SECRET=local-dev-secret
#
# Secret fields can reference environment variables from TOML, for example:
# webhook_secret = { env = "GITHUB_ACME_MAIN_WEBHOOK_SECRET" }
# bot_token = { env = "DISCORD_BOT_TOKEN" }

# --- OpenBao ---
# The compose stack starts OpenBao in in-memory dev mode for local testing only.
# Use this token for local copy-in/copy-out checks and ignored integration tests.
OPENBAO_DEV_ROOT_TOKEN=dev-only-token
# Host access with OrbStack:
# OPENBAO_ADDR=http://openbao.trogonai.orb.local:8200
# OPENBAO_TOKEN=dev-only-token
#
# --- Credential management ---
# Enables the internal /-/credentials API. Local examples use this token through
# the x-trogon-admin-token header.
# TROGON_GATEWAY_CREDENTIAL_MANAGEMENT_ADMIN_TOKEN=local-admin-token
#
# Enable runtime OpenBao credential resolution per source as needed.
# TROGON_GATEWAY_ENABLE_RUNTIME_DISCORD_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_GITHUB_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_GITLAB_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_INCIDENTIO_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_LINEAR_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_MICROSOFT_GRAPH_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_NOTION_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_SENTRY_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_SLACK_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_TELEGRAM_CREDENTIALS=true
# TROGON_GATEWAY_ENABLE_RUNTIME_TWITTER_CREDENTIALS=true

# --- NATS ---
# NATS_URL=nats://localhost:4222
# NATS_CREDS=/path/to/nats.creds
# NATS_NKEY=SU...
# NATS_USER=my-user
# NATS_PASSWORD=my-pass
# NATS_TOKEN=my-token

# --- GitHub Source ---
# GITHUB_PRIMARY_WEBHOOK_SECRET=

# --- GitLab Source ---
# GITLAB_PRIMARY_SIGNING_TOKEN=

# --- incident.io Source ---
# INCIDENTIO_PRIMARY_SIGNING_SECRET=whsec_...

# --- Linear Source ---
# LINEAR_PRIMARY_WEBHOOK_SECRET=

# --- Microsoft Graph Change Notifications Source ---
# MICROSOFT_GRAPH_PRIMARY_CLIENT_STATE=

# --- Notion Source ---
# NOTION_PRIMARY_VERIFICATION_TOKEN=

# --- Sentry Source ---
# SENTRY_PRIMARY_CLIENT_SECRET=

# --- Discord Source ---
# DISCORD_BOT_TOKEN=

# --- Telegram Source ---
# TELEGRAM_PRIMARY_WEBHOOK_SECRET=
# TELEGRAM_PRIMARY_BOT_TOKEN=

# --- Twitter/X Source ---
# TWITTER_PRIMARY_CONSUMER_SECRET=

# --- Slack Source ---
# SLACK_PRIMARY_SIGNING_SECRET=
# SLACK_PRIMARY_APP_TOKEN=

# --- Logging ---
# RUST_LOG=info

# --- Dev (ngrok tunnels) ---
# NGROK_AUTHTOKEN=
