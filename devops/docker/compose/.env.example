# --- Gateway ---
# TROGON_GATEWAY_PORT=8080
#
# Docker Compose mounts ../../../services/trogon-gateway/gateway.toml by default. That
# local config enables /sources/github/local/webhook with this dev-only secret.
TROGON_GATEWAY_LOCAL_GITHUB_WEBHOOK_SECRET=local-dev-secret
#
# Secret fields can reference environment variables from TOML, for example:
# webhook_secret = { env = "GITHUB_ACME_MAIN_WEBHOOK_SECRET" }
# bot_token = { env = "DISCORD_BOT_TOKEN" }

# --- NATS ---
# NATS_URL=nats://localhost:4222
# NATS_CREDS=/path/to/nats.creds
# NATS_NKEY=SU...
# NATS_USER=my-user
# NATS_PASSWORD=my-pass
# NATS_TOKEN=my-token

# --- GitHub Source ---
# GITHUB_PRIMARY_WEBHOOK_SECRET=

# --- GitLab Source ---
# GITLAB_PRIMARY_WEBHOOK_SECRET=

# --- incident.io Source ---
# INCIDENTIO_PRIMARY_SIGNING_SECRET=whsec_...

# --- Linear Source ---
# LINEAR_PRIMARY_WEBHOOK_SECRET=

# --- Microsoft Graph Change Notifications Source ---
# MICROSOFT_GRAPH_PRIMARY_CLIENT_STATE=

# --- Notion Source ---
# NOTION_PRIMARY_VERIFICATION_TOKEN=

# --- Sentry Source ---
# SENTRY_PRIMARY_CLIENT_SECRET=

# --- Discord Source ---
# DISCORD_BOT_TOKEN=

# --- Telegram Source ---
# TELEGRAM_PRIMARY_WEBHOOK_SECRET=
# TELEGRAM_PRIMARY_BOT_TOKEN=

# --- Twitter/X Source ---
# TWITTER_PRIMARY_CONSUMER_SECRET=

# --- Slack Source ---
# SLACK_PRIMARY_SIGNING_SECRET=

# --- Logging ---
# RUST_LOG=info

# --- Dev (ngrok tunnels) ---
# NGROK_AUTHTOKEN=
