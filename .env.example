# TrogonAI Configuration Example
# Copy this file to .env and fill in your values

# =============================================================================
# CHAT BRIDGE (TELEGRAM)
# =============================================================================

# Required: Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram user ids allowed to talk to the bot (seeded as principals at boot)
CHAT_SEED_TELEGRAM_USERS=123456789

# Optional: environment/tenant token for KV buckets and consumer names
CHAT_PREFIX=prod

# Optional: JetStream stream provisioned by the trogon-gateway Telegram source
TELEGRAM_INBOUND_STREAM=TELEGRAM

# Optional: which configured agent new conversations bind to
CHAT_AGENT_ID=default

# Optional: workspace the agent roots its sessions in
# CHAT_AGENT_CWD=/path/to/agent/workspace

# =============================================================================
# NATS / ACP
# =============================================================================

# NATS server(s), comma-separated
NATS_URL=localhost:4222

# ACP subject prefix shared with the agent behind acp-nats
ACP_PREFIX=acp

# =============================================================================
# LOGGING
# =============================================================================

# Optional: Rust log level
RUST_LOG=chat_bridge_telegram=info,info
